# ─────────────────────────────────────────────────────────────────────────────
# Sprint Society — environment variables
#
# Production target: Vercel (static client + /api serverless function) + Supabase
# Postgres. On Vercel, set these in Project → Settings → Environment Variables.
# Locally, copy this file to .env.
# ─────────────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-random-secret   # 32+ chars in production
JWT_EXPIRES_IN=7d

# CORS allow-origin for the SPA. In production set this to your deployed origin:
#   - while foolproofing:  https://<your-project>.vercel.app
#   - after domain attach: https://app.sprintsociety.in
CLIENT_URL=http://localhost:5173

# Postgres connection.
#   - Local: matches docker-compose.yml — start it with `docker compose up -d`.
#   - Production (Vercel): use the Supabase TRANSACTION POOLER connection string
#     (Supabase → Project Settings → Database → Connection pooling), which looks
#     like: postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres
#     The pooler (port 6543) is required for serverless — the direct 5432
#     connection will exhaust Postgres connections under function fan-out.
DATABASE_URL=postgresql://sprint:sprint@localhost:5432/sprint_society

# Frontend → backend wiring.
#   - Single origin (Vercel default): the SPA and the /api function share one
#     origin, so LEAVE VITE_API_URL UNSET — the client uses same-origin /api.
#   - Split deploy (frontend and an always-on backend on different origins):
#     set VITE_API_URL to the backend API base, baked into the bundle at BUILD time.
# VITE_API_URL=https://app.sprintsociety.in/api

# Real-time transport.
#   - Vercel serverless cannot host a WebSocket server, so leave this UNSET/false:
#     chat + notifications fall back to REST polling. (Supabase Realtime is the
#     planned upgrade for true real-time on Vercel.)
#   - Set true ONLY when deploying against an always-on backend running
#     server/src/websocket.ts.
# VITE_ENABLE_WS=false

# Secret guarding the Vercel Cron maintenance endpoint (/api/cron/maintenance).
# Vercel attaches `Authorization: Bearer ${CRON_SECRET}` automatically when set.
CRON_SECRET=change-this-to-a-random-secret

ANTHROPIC_API_KEY=your-anthropic-api-key

RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Razorpay signs WEBHOOKS with a separate secret (Razorpay → Settings → Webhooks),
# NOT the API key secret. Set it here; falls back to RAZORPAY_KEY_SECRET if unset.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

RESEND_API_KEY=your-resend-api-key

# Optional: error tracking + off-site backup target
# SENTRY_DSN=
# BACKUP_DIR=          # override the backup output dir (serverless writes to the OS temp dir)

# Google Sign-In (OAuth2 / Google Identity Services)
# IMPORTANT: these two MUST be the SAME OAuth client ID.
#   - GOOGLE_CLIENT_ID      → server, verifies the id_token audience (runtime).
#   - VITE_GOOGLE_CLIENT_ID → client, baked into the bundle at BUILD time by Vite.
# On Vercel, VITE_GOOGLE_CLIENT_ID must be present when the client builds, not just at runtime.
# In Google Cloud Console → Credentials → OAuth client, add your app's exact origin
# (e.g. https://<your-project>.vercel.app and https://app.sprintsociety.in) under
# "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
