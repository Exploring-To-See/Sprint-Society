# ══════════════════════════════════════════════════════════════
# KENDU STUDIO — API Configuration
# Copy this file to .env and fill in your keys
# ══════════════════════════════════════════════════════════════

# Video Generation (get ONE of these to start)
FAL_KEY=                    # https://fal.ai/dashboard → API Keys
REPLICATE_API_TOKEN=        # https://replicate.com/account/api-tokens

# AI Storyboarding (optional, falls back to templates without it)
ANTHROPIC_API_KEY=          # https://console.anthropic.com/settings/keys

# Social Media (optional, configure when ready to publish)
INSTAGRAM_TOKEN=            # Meta Developer Portal → Instagram Graph API
TWITTER_API_KEY=            # https://developer.twitter.com/en/portal/dashboard
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
YOUTUBE_API_KEY=            # Google Cloud Console → YouTube Data API v3
