{
  "name": "sprint-society",
  "version": "1.0.0",
  "private": true,
  "description": "Sprint Society — AI-powered run club platform by Kendu Entertainment",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev:video": "cd video && npx remotion preview src/index.ts",
    "render:video": "cd video && npx tsx scripts/render.ts",
    "build": "cd client && npm install --include=dev && npm run build && cd ../server && npm install --include=dev && npm run build",
    "start": "cd server && npm start",
    "migrate": "cd server && npx tsx src/database/migrate.ts",
    "setup:admin": "cd server && npx tsx src/setup-admin.ts",
    "seed": "cd server && npx tsx src/scripts/seed-dummy-data.ts",
    "test": "cd server && npm test",
    "typecheck": "cd client && tsc -b --noEmit && cd ../server && tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "//": "Server runtime deps are mirrored here so Vercel's root `npm install` resolves them when bundling the api/ serverless function (which imports server/src). The self-hosted server still uses server/package.json.",
  "dependencies": {
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.3.1",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "@anthropic-ai/sdk": "^0.52.0",
    "pino": "^9.2.0",
    "@sentry/node": "^8.0.0",
    "ws": "^8.17.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "@vercel/node": "^3.2.0",
    "@types/node": "^20.14.10",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.6",
    "@types/jsonwebtoken": "9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17"
  }
}
